---
import ExternalLink from "~/components/ExternalLink.astro";
import RiMailSendLine from "~icons/ri/mail-send-line";
import RiTwitterLine from "~icons/ri/twitter-line";
import RiGithubLine from "~icons/ri/github-line";
import RiBookReadLine from "~icons/ri/book-read-line";
import RiBook2Line from "~icons/ri/book-2-line";
import RiBellLine from "~icons/ri/bell-line";
import { COPYRIGHT_ENTITY } from "~/constants/entities";
import site from "~/config/site";

const { author, githubUsername, twitterUsername } = site;

const footerItems = [
  {
    label: "contact",
    href: "/contact",
    icon: RiMailSendLine,
    externalLink: false,
  },
  {
    label: "twitter",
    href: `https://twitter.com/${twitterUsername}`,
    icon: RiTwitterLine,
    externalLink: true,
  },
  {
    label: "github",
    href: `https://github.com/${githubUsername}`,
    icon: RiGithubLine,
    externalLink: true,
  },
  {
    label: "TIL",
    href: `/til`,
    icon: RiBookReadLine,
    externalLink: false,
  },
  {
    label: "wiki",
    href: "https://wiki.stojanow.com",
    icon: RiBook2Line,
    externalLink: true,
  },
  {
    label: "subscribe",
    href: "/subscribe",
    icon: RiBellLine,
    externalLink: false,
  },
];
---

<footer class="mx-auto mt-auto max-w-3xl px-4 py-12 pt-8 pb-8 md:pt-0">
  <nav aria-label="Footer Navigation">
    <ul
      class="text-brand-red dark:text-brand-red-dark flex flex-wrap items-baseline justify-center"
    >
      {
        footerItems.map((item) => (
          <li class="sm:mr-2">
            {item.externalLink ? (
              <ExternalLink
                href={item.href}
                className="flex items-center gap-1 border-0 p-2 no-underline filter hover:brightness-125"
                ariaLabel={`${item.label} (opens in a new tab)`}
              >
                <item.icon aria-hidden="true" focusable="false" />
                <span class="hover:text-brand-red dark:hover:text-brand-red-dark text-zinc-700 dark:text-zinc-400">
                  {item.label}
                </span>
              </ExternalLink>
            ) : (
              <a
                href={item.href}
                class="flex items-center gap-1 border-0 p-2 no-underline filter hover:brightness-125"
              >
                <item.icon aria-hidden="true" focusable="false" />
                <span class="hover:text-brand-red dark:hover:text-brand-red-dark text-zinc-700 dark:text-zinc-400">
                  {item.label}
                </span>
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </nav>

  <section
    class="m-0 block p-2 text-center text-xs leading-normal text-zinc-600 dark:text-zinc-400"
  >
    <a
      href="/copyright"
      class="text-brand-red dark:text-brand-red-dark underline filter hover:text-black hover:brightness-125 dark:hover:text-white"
      >CC BY-NC 4.0
    </a>
    <span>{`${COPYRIGHT_ENTITY} ${author}`}</span>
  </section>
</footer>
