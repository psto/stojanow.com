---
import AppTitle from "~/components/AppTitle.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostsIndex from "~/components/PostsIndex.astro";
import { getCollection } from "astro:content";
import site from "~/config/site";

const essays = await getCollection("essays");
const sortedEssays = essays.sort(
  (essayA, essayB) =>
    new Date(essayB.data.date).valueOf() - new Date(essayA.data.date).valueOf(),
);

const { author } = site;
const seoProps = {
  description: `${author}'s essays`,
  id: "essays",
  title: "Essays",
  ogType: "til" as const,
};
---

<BaseLayout {...seoProps}>
  <section
    class="relative px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28"
    aria-labelledby="essays-title"
  >
    <header
      class="prose dark:prose-dark lg:prose-lg mx-auto max-w-2xl px-4 text-center md:pt-0"
    >
      <AppTitle id="essays-title">{seoProps.title}</AppTitle>
      <hr aria-hidden="true" />
    </header>

    <PostsIndex posts={sortedEssays} />
  </section>
</BaseLayout>
