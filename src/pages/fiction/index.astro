---
import AppTitle from "~/components/AppTitle.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostsIndex from "~/components/PostsIndex.astro";
import { getCollection } from "astro:content";
import { formatContent } from "~/utils";
import site from "~/config/site";

const fiction = await getCollection("fiction");
const sortedFiction = formatContent<"fiction">(fiction);

const { author } = site;
const seoProps = {
  description: `${author}'s flash fiction and microfiction`,
  id: "fiction",
  title: "Fiction",
  ogType: "fiction" as const,
};
---

<BaseLayout {...seoProps}>
  <section
    class="relative px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28"
    aria-labelledby="fiction-title"
  >
    <header
      class="prose dark:prose-dark lg:prose-lg mx-auto max-w-2xl px-4 text-center md:pt-0"
    >
      <AppTitle id="fiction-title">{seoProps.title}</AppTitle>
      <hr aria-hidden="true" />
    </header>

    <PostsIndex posts={sortedFiction} prefix="fiction" />
  </section>
</BaseLayout>
