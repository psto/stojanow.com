---
import AppTitle from "~/components/AppTitle.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ExternalLink from "~/components/ExternalLink.astro";
import { COPYRIGHT_ENTITY } from "~/constants/entities";
import site from "~/config/site";

const { author, siteDomain } = site;

const seoProps = {
  description: `${siteDomain} copyright information. All content is released under Creative Commons Attribution-NonCommercial 4.0 International License (CC BY-NC 4.0) ${COPYRIGHT_ENTITY} ${author}`,
  id: "copyright",
  title: `Copyright ${COPYRIGHT_ENTITY}`,
};
---

<BaseLayout {...seoProps}>
  <article
    class="relative px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28"
    aria-labelledby="copyright-heading"
  >
    <header
      class="prose dark:prose-dark lg:prose-lg mx-auto max-w-2xl px-4 text-center md:pt-0"
    >
      <AppTitle id="copyright-heading">{seoProps.title}</AppTitle>
      <hr aria-hidden="true" />
    </header>

    <div class="prose dark:prose-dark relative mx-auto mt-12 max-w-2xl">
      <p>
        All text on this site is licensed under the
        <ExternalLink href="https://creativecommons.org/licenses/by-nc/4.0/">
          Creative Commons Attribution-NonCommercial International License
        </ExternalLink>. That means:
      </p>

      <section aria-labelledby="rights-heading">
        <h2 id="rights-heading">You are free to:</h2>
        <ul>
          <li>
            <strong>Share</strong> - copy and redistribute the material in any medium
            or format.
          </li>
          <li>
            <strong>Adapt</strong> - remix, transform, and build upon the material.
          </li>
        </ul>
      </section>

      <section aria-labelledby="terms-heading">
        <h2 id="terms-heading">Under the following terms:</h2>
        <dl>
          <div>
            <dt class="font-bold">Attribution</dt>
            <dd>
              You must give appropriate credit, provide a link to the license,
              and indicate if changes were made. You may do so in any reasonable
              manner, but not in any way that suggests the licensor endorses you
              or your use.
            </dd>
          </div>
          <div>
            <dt class="font-bold">NonCommercial</dt>
            <dd>You may not use the material for commercial purposes.</dd>
          </div>
        </dl>
      </section>

      <hr aria-hidden="true" />

      <footer class="italic">
        <p>
          I would be grateful if you asked permission before republishing
          anything (<a
            href="/contact"
            class="text-brand-red underline underline-offset-4 hover:brightness-125"
            >get in touch</a
          >). Thanks!
        </p>

        <p>
          Whenever I can, I try to cite sources for images. If by accident I
          misused your content,
          <a
            href="/contact"
            class="text-brand-red underline underline-offset-4 hover:brightness-125"
            >contact me</a
          >
          and I'll fix it ASAP.
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>
