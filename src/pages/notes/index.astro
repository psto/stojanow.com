---
import AppTitle from "~/components/AppTitle.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostsIndex from "~/components/PostsIndex.astro";
import { getCollection } from "astro:content";
import { formatContent } from "~/utils";
import site from "~/config/site";

const notes = await getCollection("notes");
const sortedNotes = formatContent<"notes">(notes);

const { author } = site;
const seoProps = {
  description: `${author}'s book notes. Detailed notes on books I've read. If a book is here, then it's recommended.`,
  id: "notes",
  title: "Notes",
  ogType: "note" as const,
};
---

<BaseLayout {...seoProps}>
  <section
    class="relative px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28"
    aria-labelledby="notes-title"
  >
    <header
      class="prose dark:prose-dark lg:prose-lg mx-auto max-w-2xl px-4 text-center md:pt-0"
    >
      <AppTitle id="notes-title">{seoProps.title}</AppTitle>
      <hr aria-hidden="true" />
    </header>

    <PostsIndex posts={sortedNotes} prefix="notes" />
  </section>
</BaseLayout>
