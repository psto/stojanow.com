---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import NotesHeader from "~/components/NotesHeader.astro";
import ReadingProgressBar from "~/components/ReadingProgressBar.astro";
import { formatContent } from "~/utils";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  const formattedNotes = formatContent<"notes">(notes);

  return formattedNotes.map((note) => ({
    params: { id: note.id },
    props: { note },
  }));
}

type Props = { note: CollectionEntry<"notes"> };

const { note } = Astro.props;
const { id } = Astro.params;
const { Content } = await render(note);

const seoProps = {
  description: note.data.description,
  title: note.data.title,
  id,
  ogType: "note" as const,
  image: note.data.image?.src,
};
---

<BaseLayout {...seoProps}>
  <ReadingProgressBar />
  <div class="relative px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28">
    <div class="mx-auto">
      <article
        class="prose dark:prose-dark mx-auto max-w-2xl px-4 pt-8 pb-16 md:pt-0"
      >
        <NotesHeader note={note} />

        <Content class="prose dark:prose-dark" />
      </article>
    </div>
  </div>
</BaseLayout>
