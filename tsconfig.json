{
  "extends": "astro/tsconfigs/strictest",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "preserve",
    // Path alias
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    // Provide Vite’s client types to your project
    "types": ["unplugin-icons/types/astro"]
  }
}
